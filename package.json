{
  "name": "high-line",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "VITE_CJS_TRACE=true vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:dev": "./deploy.sh dev",
    "deploy:local": "./deploy.sh",
    "start": "node server.js",
    "lint": "eslint --ext .js,.vue,.ts --ignore-path .gitignore --fix src tests",
    "lint:dry": "eslint --ext .js,.vue,.ts --ignore-path .gitignore --no-fix src tests",
    "build-storybook": "storybook build",
    "html-validate": "html-validate --ext html,vue src",
    "storybook": "storybook dev -p 6006",
    "test:watch": "vitest --watch",
    "test": "vitest --run --pool=forks",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:snapshots": "export INCLUDE_SNAPSHOT_TESTS=true && npx playwright test",
    "test:e2e:update-snapshots": "npx playwright test --update-snapshots",
    "setup:detect-secrets": "./scripts/setup-detect-secrets.sh",
    "scan:add": "detect-secrets scan --baseline .secrets.baseline --exclude-files package-lock.json",
    "scan:diff": "git diff --staged --name-only -z | xargs -0 detect-secrets-hook --baseline .secrets.baseline --exclude-files package-lock.json",
    "scan:audit": "detect-secrets audit .secrets.baseline",
    "scan:add:venv": "source .venv/bin/activate && detect-secrets scan --baseline .secrets.baseline --exclude-files package-lock.json; deactivate",
    "scan:diff:venv": "source .venv/bin/activate && git diff --staged --name-only -z | xargs -0 detect-secrets-hook --baseline .secrets.baseline --exclude-files package-lock.json; deactivate",
    "scan:audit:venv": "source .venv/bin/activate && detect-secrets audit .secrets.baseline; deactivate",
    "scan:diff:wrapped": "./scripts/wrap-detect-secrets.sh",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "@ionic/vue": "^8.0.1",
    "@rushstack/eslint-patch": "^1.10.3",
    "@trevoreyre/autocomplete-vue": "^3.0.2",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vuelidate/core": "^2.0.2",
    "@vuelidate/validators": "^2.0.2",
    "@vueuse/core": "^10.11.0",
    "@xstate/vue": "^4.0.2",
    "@zoom/videosdk": "^1.12.12",
    "amazon-chime-sdk-js": "^3.26.0",
    "awesome-phonenumber": "^2.20.0",
    "axios": "^1.5.0",
    "bootstrap": "^4.6.2",
    "case": "^1.6.3",
    "chart.js": "^4.2.0",
    "chartjs-adapter-moment": "^1.0.1",
    "exponential-backoff": "^3.1.0",
    "flush-promises": "^1.0.2",
    "gleap": "^13.5.13",
    "heic2any": "^0.0.4",
    "langfuse": "^3.25.0",
    "libphonenumber-js": "^1.10.60",
    "lodash-es": "^4.17.21",
    "maz-ui": "^3.39.1",
    "moment": "^2.29.1",
    "moment-timezone": "^0.5.33",
    "newrelic": "^11.14.0",
    "pixelmatch": "^6.0.0",
    "portal-gun": "git://github.com/claydotio/portal-gun.git",
    "posthog-js": "^1.216.1",
    "pre-commit": "^1.2.2",
    "promise-retry": "^1.1.1",
    "quill": "^2.0.2",
    "quill-cursors": "^4.0.3",
    "quill-delta": "^5.1.0",
    "sass": "1.54.8",
    "socket.io-client": "^4.7.5",
    "typeface-work-sans": "^0.0.72",
    "validator": "^13.6.0",
    "vue": "^3.4.15",
    "vue-draggable-resizable": "^3.0.0",
    "vue-router": "^4.2.5",
    "vue-select": "^4.0.0-beta.6",
    "vue-star-rating": "^2.1.0",
    "vuex": "^4.1.0",
    "xstate": "^5.19.2",
    "y-quill": "^1.0.0",
    "yjs": "^13.6.11"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^1.1.10",
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.42.1",
    "@statelyai/inspect": "^0.4.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.8",
    "@types/pixelmatch": "^5.2.6",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/test-utils": "^2.4.4",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^9.21.1",
    "html-validate": "^3.5.0",
    "html-validate-vue": "^3.2.0",
    "jsdom": "^24.0.0",
    "pg": "^8.11.5",
    "postcss": "^8.4.14",
    "prettier": "^3.2.4",
    "typescript": "^5.5.4",
    "vite": "^5.0.12",
    "vite-plugin-vue-devtools": "^7.3.9",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^1.2.2",
    "vue-tsc": "^2.1.2"
  },
  "pre-commit": [
    "scan:diff:wrapped",
    "lint:dry"
  ],
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": "~20.10.0",
    "npm": "~10.2.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.14.3"
  }
}
