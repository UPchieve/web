    "@vue/eslint-config-prettier": "^4.0.1",
    "@vue/test-utils": "^1.0.0",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^26.6.3",
    "cache-loader": "^4.1.0",
    "css-loader": "^3.6.0",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.9.0",
    "eslint-plugin-prettier": "^3.1.2",
    "eslint-plugin-storybook": "^0.6.15",
