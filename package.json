{
  "name": "high-line",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "serve": "VITE_CJS_TRACE=true vite",
    "build": "vite build",
    "build:analyze": "BUNDLE_ANALYZE=true pnpm run build",
    "preview": "vite preview",
    "deploy:dev": "./deploy.sh dev",
    "deploy:local": "./deploy.sh",
    "start": "node server.js",
    "lint": "eslint --ext .js,.vue,.ts --fix src tests",
    "lint:dry": "eslint --ext .js,.vue,.ts --no-fix src tests",
    "build-storybook": "storybook build",
    "html-validate": "html-validate --ext html,vue src",
    "storybook": "storybook dev -p 6006",
    "test:watch": "vitest --project unit --watch",
    "test": "vitest --project unit --run --pool=forks",
    "test:e2e": "pnpm playwright test",
    "test:e2e:ui": "pnpm playwright test --ui",
    "test:e2e:snapshots": "export INCLUDE_SNAPSHOT_TESTS=true && pnpm playwright test",
    "test:e2e:update-snapshots": "pnpm playwright test --update-snapshots",
    "setup:detect-secrets": "./scripts/setup-detect-secrets.sh",
    "scan:add": "./scripts/wrap-detect-secrets.sh scan",
    "scan:diff": "./scripts/wrap-detect-secrets.sh hook",
    "scan:audit": "./scripts/wrap-detect-secrets.sh audit",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "@ionic/vue": "^8.0.1",
    "@mdi/js": "^7.4.47",
    "@neoconfetti/vue": "^2.2.1",
    "@rushstack/eslint-patch": "^1.10.3",
    "@tiptap/extension-mathematics": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/vue-3": "^3.22.5",
    "@trevoreyre/autocomplete-vue": "^3.0.2",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vuelidate/core": "^2.0.2",
    "@vuelidate/validators": "^2.0.2",
    "@vueuse/core": "^10.11.0",
    "@xstate/vue": "^4.0.2",
    "amazon-chime-sdk-js": "^3.26.0",
    "awesome-phonenumber": "^7.5.0",
    "axios": "^1.15.2",
    "case": "^1.6.3",
    "chart.js": "^4.2.0",
    "chartjs-community-adapter-dayjs": "^1.0.2",
    "dayjs": "^1.11.20",
    "err-code": "1.1.2",
    "exponential-backoff": "^3.1.0",
    "gleap": "^14.6.7",
    "heic-convert": "^2.1.0",
    "ionicons": "8.0.13",
    "katex": "^0.16.45",
    "langfuse": "^3.25.0",
    "libphonenumber-js": "^1.12.33",
    "lodash-es": "^4.17.21",
    "mathlive": "^0.109.2",
    "maz-ui": "~3.50.1",
    "pixelmatch": "^6.0.0",
    "posthog-js": "^1.216.1",
    "promise-retry": "^1.1.1",
    "qr-code-styling": "^1.9.2",
    "quill": "^2.0.3",
    "quill-cursors": "^4.0.3",
    "socket.io-client": "^4.7.5",
    "typeface-work-sans": "^0.0.72",
    "validator": "^13.6.0",
    "vue": "^3.4.15",
    "vue-draggable-resizable": "^3.0.0",
    "vue-router": "~4.6.4",
    "vue-select": "^4.0.0-beta.6",
    "vue-star-rating": "^2.1.0",
    "vuetify": "^3.11.8",
    "vuex": "^4.1.0",
    "xstate": "^5.19.2",
    "y-quill": "^1.0.0",
    "yjs": "^13.6.11"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.7",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^8.4.1",
    "@fastify/pre-commit": "^2.2.1",
    "@playwright/test": "^1.42.1",
    "@statelyai/inspect": "^0.4.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.8",
    "@types/pixelmatch": "^5.2.6",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser": "^4.0.16",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/eslint-plugin": "^1.3.16",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.4",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.4.0",
    "html-validate": "^10.11.3",
    "html-validate-vue": "^7.3.0",
    "pg": "^8.11.5",
    "playwright": "^1.56.1",
    "postcss": "^8.4.14",
    "prettier": "^3.2.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "1.100.0",
    "typescript": "^5.5.4",
    "vite": "^7.3.2",
    "vite-bundle-analyzer": "^1.3.7",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^4.0.16",
    "vitest-browser-vue": "^2.0.1",
    "vue-tsc": "^3.1.1"
  },
  "pre-commit": [
    "scan:diff",
    "lint:dry"
  ],
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": "~24.15.0",
    "pnpm": ">=11.1.3 < 12"
  },
  "packageManager": "pnpm@11.11.0",
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.14.3"
  }
}
