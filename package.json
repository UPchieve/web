{
  "name": "high-line",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "VITE_CJS_TRACE=true vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore --fix src",
    "lint:dry": "eslint --ext .js,.vue --ignore-path .gitignore --no-fix src",
    "build-storybook": "storybook build",
    "html-validate": "html-validate --ext html,vue src",
    "storybook": "storybook dev -p 6006",
    "test:watch": "vitest --watch",
    "test": "vitest --run --pool=forks",
    "scan:diff": "git diff --staged --name-only -z | xargs -0 detect-secrets-hook --baseline .secrets.baseline --exclude-files package-lock.json",
    "scan:audit": "detect-secrets audit .secrets.baseline"
  },
  "dependencies": {
    "@sentry/browser": "^5.30.0",
    "@sentry/integrations": "^5.30.0",
    "@trevoreyre/autocomplete-vue": "^2.0.2",
    "@vuelidate/core": "^2.0.2",
    "@vuelidate/validators": "^2.0.2",
    "awesome-phonenumber": "^2.20.0",
    "axios": "^1.5.0",
    "bootstrap": "^4.6.2",
    "bootstrap-vue": "^2.23.0",
    "case": "^1.6.3",
    "chart.js": "^4.2.0",
    "chartjs-adapter-moment": "^1.0.1",
    "cors": "^2.8.5",
    "exponential-backoff": "^3.1.0",
    "express": "^4.18.1",
    "gleap": "^13.0.2",
    "heic2any": "^0.0.4",
    "helmet": "^4.6.0",
    "lodash-es": "^4.17.21",
    "moment": "^2.29.1",
    "moment-timezone": "^0.5.33",
    "newrelic": "^9.0.0",
    "pino": "^8.5.0",
    "pino-http": "^8.2.0",
    "portal-gun": "git://github.com/claydotio/portal-gun.git",
    "posthog-js": "^1.75.4",
    "pre-commit": "^1.2.2",
    "promise-retry": "^1.1.1",
    "quill": "^1.3.7",
    "quill-cursors": "^3.0.1",
    "quill-delta": "^4.2.2",
    "sass": "1.54.8",
    "socket.io-client": "^2.5.0",
    "typeface-work-sans": "^0.0.72",
    "validator": "^13.6.0",
    "vue": "~2.7.0",
    "vue-crono": "^2.0.9",
    "vue-js-toggle-button": "^1.3.3",
    "vue-phone-number-input": "^0.2.6",
    "vue-router": "^3.0.3",
    "vue-select": "^3.1.0",
    "vue-socket.io": "^3.0.10",
    "vue-star-rating": "^1.6.1",
    "vue-template-compiler": "^2.7.0",
    "vuex": "^3.0.1",
    "y-quill": "^0.1.5",
    "yjs": "^13.6.11"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^7.6.9",
    "@storybook/addon-actions": "^7.6.9",
    "@storybook/addon-essentials": "^7.6.8",
    "@storybook/addon-interactions": "^7.6.8",
    "@storybook/addon-links": "^7.6.8",
    "@storybook/blocks": "^7.6.8",
    "@storybook/vue": "^7.6.8",
    "@storybook/vue-vite": "^7.6.8",
    "@vitejs/plugin-vue2": "^2.3.1",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/test-utils": "^1.0.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-storybook": "^0.6.15",
    "eslint-plugin-vue": "^9.21.1",
    "html-validate": "^3.5.0",
    "html-validate-vue": "^3.2.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.14",
    "prettier": "^3.2.4",
    "storybook": "^7.6.8",
    "storybook-addon-pseudo-states": "^2.1.2",
    "vite": "^5.0.12",
    "vite-plugin-vue2-svg": "^0.4.0",
    "vitest": "^1.2.2"
  },
  "pre-commit": [
    "scan:diff",
    "lint:dry"
  ],
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": "~20.10.0",
    "npm": "~10.2.3"
  }
}
