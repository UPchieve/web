{
  "name": "high-line",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "VITE_CJS_TRACE=true vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:local": "echo '{\"version\": \"$(date +%s)\"}' > public/version.json && doppler run --token $(op read op://private/doppler-high-line/password) -- npm run build && npx swa deploy --env production ./dist",
    "start": "node server.js",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore --fix src",
    "lint:dry": "eslint --ext .js,.vue --ignore-path .gitignore --no-fix src",
    "build-storybook": "storybook build",
    "html-validate": "html-validate --ext html,vue src",
    "storybook": "storybook dev -p 6006",
    "test:watch": "vitest --watch",
    "test": "vitest --run --pool=forks",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:snapshots": "export INCLUDE_SNAPSHOT_TESTS=true && npx playwright test",
    "test:e2e:update-snapshots": "npx playwright test --update-snapshots",
    "scan:add": "detect-secrets scan --baseline .secrets.baseline --exclude-files package-lock.json",
    "scan:diff": "git diff --staged --name-only -z | xargs -0 detect-secrets-hook --baseline .secrets.baseline --exclude-files package-lock.json",
    "scan:audit": "detect-secrets audit .secrets.baseline"
  },
  "dependencies": {
    "@ionic/vue": "^8.0.1",
    "@trevoreyre/autocomplete-vue": "^3.0.2",
    "@vuelidate/core": "^2.0.2",
    "@vuelidate/validators": "^2.0.2",
    "awesome-phonenumber": "^2.20.0",
    "axios": "^1.5.0",
    "bcrypt": "^5.1.1",
    "bootstrap": "^4.6.2",
    "case": "^1.6.3",
    "chart.js": "^4.2.0",
    "chartjs-adapter-moment": "^1.0.1",
    "cors": "^2.8.5",
    "exponential-backoff": "^3.1.0",
    "express": "^4.18.1",
    "flush-promises": "^1.0.2",
    "gleap": "^13.5.13",
    "heic2any": "^0.0.4",
    "helmet": "^4.6.0",
    "id128": "^1.6.6",
    "libphonenumber-js": "^1.10.60",
    "lodash-es": "^4.17.21",
    "maz-ui": "^3.39.1",
    "moment": "^2.29.1",
    "moment-timezone": "^0.5.33",
    "newrelic": "^11.14.0",
    "pino": "^8.5.0",
    "pino-http": "^8.2.0",
    "portal-gun": "git://github.com/claydotio/portal-gun.git",
    "posthog-js": "^1.116.6",
    "pre-commit": "^1.2.2",
    "promise-retry": "^1.1.1",
    "quill": "^1.3.7",
    "quill-cursors": "^3.0.1",
    "quill-delta": "^4.2.2",
    "sass": "1.54.8",
    "socket.io-client": "^4.7.5",
    "typeface-work-sans": "^0.0.72",
    "validator": "^13.6.0",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5",
    "vue-select": "^4.0.0-beta.6",
    "vue-star-rating": "^2.1.0",
    "vuex": "^4.1.0",
    "y-quill": "^0.1.5",
    "yjs": "^13.6.11"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^1.1.10",
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.42.1",
    "@types/node": "^20.11.30",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/test-utils": "^2.4.4",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^9.21.1",
    "html-validate": "^3.5.0",
    "html-validate-vue": "^3.2.0",
    "jsdom": "^24.0.0",
    "pg": "^8.11.5",
    "postcss": "^8.4.14",
    "prettier": "^3.2.4",
    "vite": "^5.0.12",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^1.2.2"
  },
  "pre-commit": [
    "scan:diff",
    "lint:dry"
  ],
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": "~20.10.0",
    "npm": "~10.2.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.14.3"
  }
}